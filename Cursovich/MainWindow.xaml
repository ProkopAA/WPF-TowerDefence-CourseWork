<Window x:Name="window" x:Class="Cursovich.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cursovich"
        mc:Ignorable="d"
        Title="ZONE: Before the Blowout" 
        Height="500" 
        Width="1000"
        ResizeMode="NoResize"
        WindowStyle="None">
    <Grid x:Name="MainGrid">

        <Border Background="Gray" Grid.Row="0" MouseDown="TitleBar_MouseDown" Margin="0,0,0,470">
            <Grid>
                <TextBlock Text="ZONE: Before the Blowout" VerticalAlignment="Center" Foreground="White" Margin="10"/>
                <Button Content="X" HorizontalAlignment="Left" Margin="969,0,0,0" VerticalAlignment="Center" Height="30" Width="31" BorderBrush="Red" Background="Red" FontSize="22" FontWeight="Bold" Click="Button_Click"/>
            </Grid>
        </Border>

        <Grid x:Name="GameGrid"/>
        <Grid x:Name="MenuGrid">
            <Image HorizontalAlignment="Left" Height="500" VerticalAlignment="Top" Width="1000" Source="/background.png"/>
            <Label x:Name="GameName3" Content="ZONE" HorizontalAlignment="Center" Margin="0,45,0,0" VerticalAlignment="Top" FontFamily="Rockwell Extra Bold" Height="93" FontSize="72" Width="242" FontWeight="Bold" Foreground="White"/>
            <Label x:Name="GameName4" Content="Before The Blowout" HorizontalAlignment="Center" Margin="0,118,0,0" VerticalAlignment="Top" FontFamily="Rockwell Extra Bold" Height="66" FontSize="48" Width="584" FontWeight="Bold" Foreground="White"/>
            <Button x:Name="NewGame_Button1" Content="НОВАЯ ИГРА" HorizontalAlignment="Center" VerticalAlignment="Top" Height="60" Width="370" FontSize="36" FontWeight="Bold" FontFamily="Arial Black" Click="NewGame_Click" Background="#99DDDDDD" Margin="0,250,0,0"/>
            <Button x:Name="ExitGame_Button1" Content="ПОКИНУТЬ ИГРУ" HorizontalAlignment="Center" VerticalAlignment="Top" Height="60" Width="370" FontSize="36" FontWeight="Bold" FontFamily="Arial Black" Margin="0,352,0,0" Click="Exit_Click" Background="#99DDDDDD"/>
            <Border Background="Gray" Grid.Row="0" MouseDown="TitleBar_MouseDown" Margin="0,0,0,470">
                <Grid>
                    <TextBlock Text="ZONE: Before the Blowout" VerticalAlignment="Center" Foreground="White" Margin="10"/>
                    <Button Content="X" HorizontalAlignment="Left" Margin="969,0,0,0" VerticalAlignment="Center" Height="30" Width="31" BorderBrush="Red" Background="Red" FontSize="22" FontWeight="Bold" Click="Button_Click"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
    
